{
  "name": "explainable-synthetic-media-analysis-frontend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "dev": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev",
    "dev:clean": "npm run clean && npm run dev",
    "build": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "next": "14.2.30",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "22.13.5",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/three": "^0.183.1",
    "typescript": "5.7.3"
  }
}
